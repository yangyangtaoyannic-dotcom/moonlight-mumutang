        <CheckBoxPreference
            android:key="checkbox_enable_game_manager_quest"
            android:title="禁用游戏模式"
            android:summary="可能对Quest 安卓13及以上版本有用"
            android:defaultValue="false"/>

        <Preference
            android:key="import_switch_button_file"
            android:title="导入自定义无障碍配置文件"
            android:summary="每次都会覆盖原来的，请注意备份。"
            />

        <CheckBoxPreference
            android:key="checkbox_enable_accessibility_show_log"
            android:title="无障碍键盘模式显示捕获的键值"
            android:summary="打开无障碍键盘，在月光app任意界面，输入按键，会弹出键值，用于自定义无障碍配置文件使用。"
            android:defaultValue="false"/>

    </PreferenceCategory>


    <PreferenceCategory android:title="虚拟按键"
        android:key="category_axixi_settings">

        <CheckBoxPreference
            android:key="checkbox_enable_keyboard"
            android:title="显示虚拟按键"
            android:summary="在触摸屏上显示一层虚拟特殊按键。
            \n按键透明度与上方选项中虚拟手柄共用。"
            android:defaultValue="false"/>

        <ListPreference
            android:key="keyboard_axi_list"
            android:title="默认布局方案"
            android:summary="横竖屏支持单独配置。"
            android:entries="@array/keyboard_axi_names"
            android:entryValues="@array/keyboard_axi_values"
            android:defaultValue="OSC_Keyboard" />

        <CheckBoxPreference
            android:key="checkbox_vibrate_keyboard"
            android:title="@string/title_checkbox_vibrate_osc"
            android:summary="点按屏幕按键时，会触发手机马达震动，此选项也可用于虚拟手柄按钮。"
            android:defaultValue="false" />

        <Preference
            android:key="import_keyboard_file"
            android:title="导入虚拟按键配置"
            android:summary="选择一个配置文件，覆盖默认选择的布局方案。(仅横屏模式)"
            />

        <Preference
            android:key="export_keyboard_file"
            android:title="导出虚拟按键配置"
            android:summary="导出默认选择的布局方案的配置文件。(仅横屏模式)"
            />

    </PreferenceCategory>

    <PreferenceCategory android:title="音频震动Beta"
        android:key="category_axixi_audio_rumble">
        <CheckBoxPreference
            android:key="checkbox_enable_audio_haptics"
            android:title="启用音频震动"
            android:summary="把串流音频转换成震动反馈，更适合爆炸、撞击、低频场景"
            android:defaultValue="false" />
        <ListPreference
            android:key="list_audio_haptics_output_target"
            android:dependency="checkbox_enable_audio_haptics"
            android:title="音频震动输出目标"
            android:summary="选择输出到手机，或输出到已接入的手柄"
            android:entries="@array/audio_haptics_output_target_names"
            android:entryValues="@array/audio_haptics_output_target_values"
            android:defaultValue="phone" />
        <com.limelight.preferences.SeekBarPreference
            android:key="seekbar_audio_haptics_strength"
            android:dependency="checkbox_enable_audio_haptics"
            android:defaultValue="100"
            seekbar:min="25"
            seekbar:step="5"
            seekbar:keyStep="5"
            android:max="200"
            android:summary="调整手机或者手柄音频震动强度。"
            android:text="%"
            android:title="音频震动强度" />
        <ListPreference
            android:key="list_audio_haptics_voice_filter"
            android:dependency="checkbox_enable_audio_haptics"
            android:title="语音过滤"
            android:summary="降低人声、语音聊天、播报声对震动的触发"
            android:entries="@array/audio_haptics_voice_filter_names"
            android:entryValues="@array/audio_haptics_voice_filter_values"
            android:defaultValue="off" />
        <CheckBoxPreference
            android:key="checkbox_audio_haptics_keep_controller_rumble"
            android:dependency="checkbox_enable_audio_haptics"
            android:title="保留普通手柄震动"
            android:summary="当输出目标为手柄时，是否继续保留游戏原本的手柄震动。默认关闭。"
            android:defaultValue="false" />

    </PreferenceCategory>

    <PreferenceCategory android:title="备份恢复数据【注意数据安全】"
        android:key="category_axixi_back_data">

        <Preference
            android:key="export_computers_data_file"
            android:title="导出配对的电脑数据库文件"
            android:summary="导出一个db格式的sqlite数据库文件"
            />

        <Preference
            android:key="export_https_data_crt_file"
            android:title="导出网络请求的证书文件"
            android:summary="导出一个crt格式的证书文件"
            />

        <Preference
            android:key="export_https_data_key_file"
            android:title="导出网络请求的key文件"
            android:summary="导出一个key格式的验证文件"
            />

        <Preference
            android:key="import_computers_data_file"
            android:title="导入配对的电脑数据库文件"
            android:summary="选择db数据库文件，会覆盖更新原有的电脑列表，需要重新打开APP生效。"
            />

        <Preference
            android:key="import_https_data_crt_file"
            android:title="导入网络请求的证书文件"
            android:summary="导入一个crt格式的证书文件"
            />

        <Preference
            android:key="import_https_data_key_file"
            android:title="导入网络请求的key文件"
            android:summary="导入一个key格式的验证文件"
            />

    </PreferenceCategory>

    <PreferenceCategory android:title="主屏幕设置"
        android:key="category_axixi_screen">

        <CheckBoxPreference
            android:key="checkbox_enable_screen_bg"
            android:title="使用自定义背景图"
            android:summary="不勾选则使用默认背景,安卓10以上支持"
            android:defaultValue="false" />

        <Preference
            android:key="import_image_file_key"
            android:title="设置主屏幕背景图"
            android:summary="选择一张图片，旋转屏幕生效~\n容错率不是很高，所以图片大小和类型别太过分，小心崩溃~\n如果崩溃了清除数据可解决~"
            />

        <CheckBoxPreference
            android:key="checkbox_enable_screen_obscure"
            android:title="背景图高斯模糊"
            android:summary="自定义背景图是否进行高斯模糊处理，安卓12以上支持。"
            android:defaultValue="true" />

        <EditTextPreference
            android:key="change_screen_label_key"
            android:defaultValue="@string/app_label"
            android:singleLine="true"
            android:dialogTitle="设置主屏幕左侧文本"
            android:summary="输入你喜欢的文本"
            android:dialogMessage="输入你喜欢的文本~"
            android:title="设置主屏幕左侧文本" />

        <CheckBoxPreference
            android:key="checkbox_enable_pass_menu"
            android:title="忽略掉应用列表菜单选项"
            android:summary="开启此功能，点击图标可直接进入串流界面，无需再点击弹出的菜单选项。"
            android:defaultValue="false" />

    </PreferenceCategory>

