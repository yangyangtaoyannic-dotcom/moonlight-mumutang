    <PreferenceCategory android:title="木木糖的日常设置"
        android:key="category_axixi_settings">

        <CheckBoxPreference
            android:key="checkbox_enable_quit_dialog"
            android:title="快捷选项"
            android:summary="开启后，串流界面点击手机物理返回键 展示相关选项！
